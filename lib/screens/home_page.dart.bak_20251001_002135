                              isOpened ? 'Açıldı' : 'Beklemede',
                              style: TextStyle(
                                fontSize: 12,
                                fontWeight: FontWeight.w600,
                                color: isOpened ? Colors.green.shade600 : Colors.orange.shade600,
                              ),
                            ),
                          ),
